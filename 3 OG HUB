local function createTab(tabName)
	local scroll = Instance.new("ScrollingFrame", contentFrame)
	scroll.Name = tabName .. "Tab"
	scroll.Size = UDim2.new(1, 0, 1, 0)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 4
	scroll.ScrollBarImageColor3 = GOLD_ACCENT
	scroll.Visible = false
	
	local list = Instance.new("UIListLayout", scroll)
	list.Padding = UDim.new(0, 6)
	list.HorizontalAlignment = Enum.HorizontalAlignment.Center
	
	list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y + 25)
	end)
	
	-- Nav Button
	local navBtn = Instance.new("TextButton", sidebar)
	navBtn.Size = UDim2.new(0, 110, 0, 32)
	navBtn.BackgroundTransparency = 1
	navBtn.Text = tabName
	navBtn.TextColor3 = DIM
	navBtn.Font = Enum.Font.GothamBold
	navBtn.TextSize = 12
	
	navBtn.MouseButton1Click:Connect(function()
		for _, t in pairs(tabs) do
			t.Scroll.Visible = false
			t.Btn.TextColor3 = DIM
		end
		scroll.Visible = true
		navBtn.TextColor3 = GOLD_ACCENT
		currentTab = tabName
	end)
	
	tabs[tabName] = { Scroll = scroll, Btn = navBtn }
	if not currentTab then
		scroll.Visible = true
		navBtn.TextColor3 = GOLD_ACCENT
		currentTab = tabName
	end
	return scroll
end

