-- ─── MOVEMENT RUNTIME CORE ENGINE ─────────────────────────────────────────
RunService.RenderStepped:Connect(function()
	local char = LP.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end
	
	-- Anti Ragdoll Enforcement
	if State.antiRagdollEnabled and hum.PlatformStand then
		hum.PlatformStand = false
		root.RotVelocity = Vector3.new(0,0,0)
	end
	
	-- Automatic Directional Path Corridors
	if State.autoLeftEnabled then
		root.Velocity = Vector3.new(-NS, root.Velocity.Y, root.Velocity.Z)
		return
	elseif State.autoRightEnabled then
		root.Velocity = Vector3.new(NS, root.Velocity.Y, root.Velocity.Z)
		return
	end
	
	-- Basic Manual WalkSpeed Modifiers (Velocity Override Engine)
	local md = hum.MoveDirection
	if md.Magnitude > 0 then
		local targetSpeed = NS
		if State.laggerToggled then
			targetSpeed = LS
		elseif State.speedToggled then
			targetSpeed = CS
		end
		root.Velocity = Vector3.new(md.X * targetSpeed, root.Velocity.Y, md.Z * targetSpeed)
	end
end)

-- Infinite Jump Hook
UIS.JumpRequest:Connect(function()
	if not State.infJumpEnabled then return end
	local char = LP.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then root.Velocity = Vector3.new(root.Velocity.X, 48, root.Velocity.Z) end
end)

