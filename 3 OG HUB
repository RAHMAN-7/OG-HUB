local padButtons = {}

local function buildPadButton(text, stateKey, actionCallback)
	local b = Instance.new("TextButton", buttonPad)
	b.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
	b.Text = text
	b.TextColor3 = Color3.fromRGB(255, 255, 255)
	b.Font = Enum.Font.GothamBlack
	b.TextSize = 10
	b.TextWrapped = true
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
	local s = Instance.new("UIStroke", b)
	s.Color = Color3.fromRGB(40, 40, 40)
	
	local function updateVisuals()
		if stateKey and State[stateKey] then
			b.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
			b.TextColor3 = Color3.fromRGB(0, 0, 0)
		else
			b.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
			b.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
	end
	
	b.MouseButton1Click:Connect(function()
		if stateKey then
			State[stateKey] = not State[stateKey]
			updateVisuals()
		else
			b.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
			b.TextColor3 = Color3.fromRGB(0, 0, 0)
			task.wait(0.15)
			b.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
			b.TextColor3 = Color3.fromRGB(255, 255, 255)
		end
		if actionCallback then actionCallback() end
	end)
	
	padButtons[text] = updateVisuals
	return b
end

local function syncAllPadVisuals()
	for _, refresh in pairs(padButtons) do refresh() end
end

