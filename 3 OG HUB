local function rowToggle(tabScroll, label, sub, default, onToggle)
	local c = baseCard(tabScroll, sub and 48 or 42)
	
	local tl = Instance.new("TextLabel", c)
	tl.Size = UDim2.new(0, 240, 0, 16)
	tl.Position = UDim2.new(0, 12, 0, sub and 6 or 13)
	tl.BackgroundTransparency = 1
	tl.Text = label
	tl.TextColor3 = WHITE
	tl.Font = Enum.Font.GothamBold
	tl.TextSize = 11
	tl.TextXAlignment = Enum.TextXAlignment.Left
	
	if sub then
		local sl = Instance.new("TextLabel", c)
		sl.Size = UDim2.new(0, 240, 0, 12)
		sl.Position = UDim2.new(0, 12, 0, 24)
		sl.BackgroundTransparency = 1
		sl.Text = sub
		sl.TextColor3 = DIM
		sl.Font = Enum.Font.Gotham
		sl.TextSize = 9
		sl.TextXAlignment = Enum.TextXAlignment.Left
	end
	
	local tg = Instance.new("TextButton", c)
	tg.Size = UDim2.new(0, 38, 0, 20)
	tg.Position = UDim2.new(1, -50, 0.5, -10)
	tg.BackgroundColor3 = default and GOLD_ACCENT or CARD_HOV
	tg.Text = ""
	Instance.new("UICorner", tg).CornerRadius = UDim.new(0, 10)
	local tgStroke = Instance.new("UIStroke", tg)
	tgStroke.Color = default and GOLD_ACCENT or BORDER
	
	local active = default
	tg.MouseButton1Click:Connect(function()
		active = not active
		TweenService:Create(tg, TweenInfo.new(0.12), {BackgroundColor3 = active and GOLD_ACCENT or CARD_HOV}):Play()
		TweenService:Create(tgStroke, TweenInfo.new(0.12), {Color = active and GOLD_ACCENT or BORDER}):Play()
		if onToggle then onToggle(active) end
	end)
end

