-- ─── RUNTIME SYSTEM INTEGRATION ──────────────────────────────────────────
RunService.RenderStepped:Connect(function()
	local char = LP.Character; local hum = char and char:FindFirstChildOfClass("Humanoid")
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end
	
	if not State.autoLeftEnabled and not State.autoRightEnabled and not State.autoBatToggled then
		local md = hum.MoveDirection
		if md.Magnitude > 0 then
			local targetSpeed = State.laggerToggled and LS or (State.speedToggled and CS or NS)
			root.Velocity = Vector3.new(md.X * targetSpeed, root.Velocity.Y, md.Z * targetSpeed)
		end
	end
end)

UIS.JumpRequest:Connect(function()
	if not State.infJumpEnabled then return end
	local char = LP.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
	if root then root.Velocity = Vector3.new(root.Velocity.X, 52, root.Velocity.Z) end
end)

