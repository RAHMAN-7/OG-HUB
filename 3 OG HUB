local function registerTab(name)
	local scroll = Instance.new("ScrollingFrame", contentFrame)
	scroll.Size = UDim2.new(1, 0, 1, 0)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 2
	scroll.ScrollBarImageColor3 = Color3.fromRGB(212, 175, 55)
	scroll.Visible = false
	
	local list = Instance.new("UIListLayout", scroll)
	list.Padding = UDim.new(0, 6)
	list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y + 10)
	end)
	
	local btn = Instance.new("TextButton", sidebar)
	btn.Size = UDim2.new(1, 0, 0, 34)
	btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(160, 160, 160)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 11
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	local bStr = Instance.new("UIStroke", btn)
	bStr.Color = Color3.fromRGB(35, 35, 35)
	
	btn.MouseButton1Click:Connect(function()
		for _, t in pairs(tabs) do
			t.S.Visible = false
			t.B.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
			t.B.TextColor3 = Color3.fromRGB(160, 160, 160)
		end
		scroll.Visible = true
		btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		activeTab = name
	end)
	
	tabs[name] = { S = scroll, B = btn }
	if not activeTab then
		scroll.Visible = true
		btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		activeTab = name
	end
	return scroll
end

